{
  "_config": "layered",
  "_host": "cc",
  "_doc": "Layered: native settings.json deny/ask/allow (from native.json) AND the AGT plugin hooks ON together. Attribution uses Claude Code's DOCUMENTED precedence: Hooks -> Deny -> permission mode -> Allow -> ask-callback. So a plugin PreToolUse deny (hook) is attributed to the plugin layer and wins even over native allow; a native deny wins over native allow; where both pass, the case is allowed. This config proves the plugin's MARGINAL value: cases the plugin uniquely catches must be ones native genuinely allowed (internal-consistency check the skeptic runs).",
  "plugin_enabled": true,
  "policy_path": "../../plugins/agt-governance/config/default-policy.json",
  "policy_profile": "default",
  "_native_rules_from": "./native.json",
  "_precedence": "Hooks -> Deny -> permissionMode -> Allow -> ask-callback (Claude Code documented order)",
  "settings": {
    "permissions": {
      "defaultMode": "default",
      "deny": [
        "Bash(rm -rf:*)",
        "Bash(rm -fr:*)",
        "Bash(rm -r:*)",
        "Bash(rm --recursive:*)",
        "Bash(rmdir /s:*)",
        "Bash(Remove-Item -Recurse:*)",
        "Bash(Remove-Item -r:*)",
        "Bash(find:* -delete)",
        "Bash(find:* -exec rm:*)",
        "Bash(xargs rm:*)",
        "Bash(curl:*| sh)",
        "Bash(curl:*| bash)",
        "Bash(wget:*| sh)",
        "Bash(wget:*| bash)",
        "Bash(Invoke-Expression:*)",
        "Bash(iex:*)",
        "Bash(:* -EncodedCommand:*)",
        "Bash(certutil:* -urlcache:*)",
        "Bash(cat:*.env)",
        "Bash(cat:*id_rsa*)",
        "Bash(cat:*id_ed25519*)",
        "Bash(cat:*/.ssh/*)",
        "Bash(cat:*/.aws/*)",
        "Bash(cat:*.npmrc)",
        "Bash(cat:*/.git-credentials)",
        "Bash(cat:*.netrc)",
        "Bash(Get-Content:*.env)",
        "Bash(Get-Content:*id_rsa*)",
        "Bash(printenv:*)",
        "Bash(env)",
        "Bash(cat:*/proc/*/environ)",
        "Bash(gh auth token:*)",
        "Bash(az account get-access-token:*)",
        "Bash(kubectl config view --raw:*)",
        "Bash(curl:*169.254.169.254*)",
        "Bash(curl:*metadata.google.internal*)",
        "Bash(wget:*169.254.169.254*)",
        "Read(//**/.env)",
        "Read(//**/.env.*)",
        "Read(//**/id_rsa)",
        "Read(//**/id_ed25519)",
        "Read(//**/.ssh/**)",
        "Read(//**/.aws/**)",
        "Read(//**/.git-credentials)",
        "Read(//**/.npmrc)",
        "Read(//**/.netrc)",
        "WebFetch(domain:169.254.169.254)",
        "WebFetch(domain:metadata.google.internal)"
      ],
      "ask": [
        "Bash(echo:*>> *.bashrc)",
        "Bash(echo:*>> *.zshrc)",
        "Bash(:*>> *.profile)",
        "Bash(tee:*.gitconfig)",
        "Edit(//**/.bashrc)",
        "Edit(//**/.zshrc)",
        "Edit(//**/.git/hooks/**)",
        "Edit(//**/.vscode/tasks.json)",
        "Bash(:*)"
      ],
      "_allow_note": "Native allow list kept identical to native.json per skeptic Q2 ruling: removed the dead rm -rf node_modules/dist/build entries (overridden by the blanket Bash(rm -rf:*) deny under CC Deny-before-Allow).",
      "allow": [
        "Read(//**)",
        "Bash(git status:*)",
        "Bash(git diff:*)",
        "Bash(git log:*)",
        "Bash(npm run:*)",
        "Bash(npm test:*)",
        "Bash(ls:*)"
      ]
    }
  }
}
